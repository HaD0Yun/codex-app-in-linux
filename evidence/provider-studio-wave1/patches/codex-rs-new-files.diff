+use anyhow::Result;
+use app_test_support::ProviderStudioMock;
+use reqwest::StatusCode;
+use serde_json::Value;
+
+#[tokio::test]
+async fn provider_studio_mock_serves_healthy_models_when_requested() -> Result<()> {
+    let provider = ProviderStudioMock::healthy_models().await;
+
+    let response = reqwest::get(provider.models_url()).await?;
+
+    assert_eq!(response.status(), StatusCode::OK);
+    let body = response.json::<Value>().await?;
+    assert_eq!(body["object"], "list");
+    assert_eq!(body["data"][0]["id"], "provider-studio-model");
+    Ok(())
+}
+
+#[tokio::test]
+async fn provider_studio_mock_returns_not_found_when_models_endpoint_missing() -> Result<()> {
+    let provider = ProviderStudioMock::missing_models().await;
+
+    let response = reqwest::get(provider.models_url()).await?;
+
+    assert_eq!(response.status(), StatusCode::NOT_FOUND);
+    Ok(())
+}
+
+#[tokio::test]
+async fn provider_studio_mock_returns_responses_404_when_configured() -> Result<()> {
+    let provider = ProviderStudioMock::responses_404().await;
+
+    let response = reqwest::Client::new()
+        .post(provider.responses_url())
+        .send()
+        .await?;
+
+    assert_eq!(response.status(), StatusCode::NOT_FOUND);
+    Ok(())
+}
+
+#[tokio::test]
+async fn provider_studio_mock_streams_assistant_message_when_requested() -> Result<()> {
+    let provider = ProviderStudioMock::streaming_assistant("fixture assistant").await;
+
+    let response = reqwest::Client::new()
+        .post(provider.responses_url())
+        .send()
+        .await?;
+
+    assert_eq!(response.status(), StatusCode::OK);
+    assert_eq!(
+        response
+            .headers()
+            .get("content-type")
+            .and_then(|value| value.to_str().ok()),
+        Some("text/event-stream")
+    );
+    let body = response.text().await?;
+    assert!(body.contains("fixture assistant"));
+    assert!(body.contains("response.completed"));
+    Ok(())
+}
+
+#[tokio::test]
+async fn provider_studio_mock_streams_tool_call_when_requested() -> Result<()> {
+    let provider = ProviderStudioMock::streaming_tool_call().await;
+
+    let response = reqwest::Client::new()
+        .post(provider.responses_url())
+        .send()
+        .await?;
+
+    assert_eq!(response.status(), StatusCode::OK);
+    let body = response.text().await?;
+    assert!(body.contains("function_call"));
+    assert!(body.contains("provider_studio_mock_tool"));
+    Ok(())
+}
+
+#[tokio::test]
+async fn provider_studio_mock_returns_auth_required_401_when_configured() -> Result<()> {
+    let provider = ProviderStudioMock::auth_required_401().await;
+
+    let response = reqwest::get(provider.models_url()).await?;
+
+    assert_eq!(response.status(), StatusCode::UNAUTHORIZED);
+    assert_eq!(
+        response
+            .headers()
+            .get("www-authenticate")
+            .and_then(|value| value.to_str().ok()),
+        Some("Bearer")
+    );
+    Ok(())
+}
