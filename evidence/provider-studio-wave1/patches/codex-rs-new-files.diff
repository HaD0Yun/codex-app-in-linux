index 0000000..0bbf867
--- /dev/null
+++ b/codex-rs/app-server/tests/common/provider_studio_mock.rs
@@ -0,0 +1,114 @@
+use core_test_support::responses;
+use serde_json::json;
+use wiremock::Mock;
+use wiremock::MockServer;
+use wiremock::ResponseTemplate;
+use wiremock::matchers::method;
+use wiremock::matchers::path;
+
+pub struct ProviderStudioMock {
+    server: MockServer,
+}
+
+impl ProviderStudioMock {
+    pub async fn healthy_models() -> Self {
+        let provider = Self::start().await;
+        Mock::given(method("GET"))
+            .and(path("/v1/models"))
+            .respond_with(ResponseTemplate::new(200).set_body_json(json!({
+                "object": "list",
+                "data": [{
+                    "id": "provider-studio-model",
+                    "object": "model",
+                    "created": 1_700_000_000_i64,
+                    "owned_by": "provider-studio-test"
+                }]
+            })))
+            .mount(&provider.server)
+            .await;
+        provider
+    }
+
+    pub async fn missing_models() -> Self {
+        Self::start().await
+    }
+
+    pub async fn responses_404() -> Self {
+        Self::responses_response(ResponseTemplate::new(404).set_body_json(json!({
+            "error": {
+                "message": "fixture responses endpoint missing",
+                "type": "not_found_error"
+            }
+        })))
+        .await
+    }
+
+    pub async fn streaming_assistant(message: &str) -> Self {
+        let body = responses::sse(vec![
+            responses::ev_response_created("provider-studio-resp-1"),
+            responses::ev_assistant_message("provider-studio-msg-1", message),
+            responses::ev_completed("provider-studio-resp-1"),
+        ]);
+        Self::responses_response(responses::sse_response(body)).await
+    }
+
+    pub async fn streaming_tool_call() -> Self {
+        let body = responses::sse(vec![
+            responses::ev_response_created("provider-studio-resp-1"),
+            responses::ev_function_call(
+                "provider-studio-call-1",
+                "provider_studio_mock_tool",
+                r#"{"fixture":true}"#,
+            ),
+            responses::ev_completed("provider-studio-resp-1"),
+        ]);
+        Self::responses_response(responses::sse_response(body)).await
+    }
+
+    pub async fn auth_required_401() -> Self {
+        let provider = Self::start().await;
+        let response = ResponseTemplate::new(401)
+            .insert_header("www-authenticate", "Bearer")
+            .set_body_json(json!({
+                "error": {
+                    "message": "missing provider studio test token",
+                    "type": "authentication_error"
+                }
+            }));
+        Mock::given(method("GET"))
+            .and(path("/v1/models"))
+            .respond_with(response.clone())
+            .mount(&provider.server)
+            .await;
+        Mock::given(method("POST"))
+            .and(path("/v1/responses"))
+            .respond_with(response)
+            .mount(&provider.server)
+            .await;
+        provider
+    }
+
+    pub fn models_url(&self) -> String {
+        format!("{}/v1/models", self.server.uri())
+    }
+
+    pub fn responses_url(&self) -> String {
+        format!("{}/v1/responses", self.server.uri())
+    }
+
+    async fn start() -> Self {
+        Self {
+            server: MockServer::start().await,
+        }
+    }
+
+    async fn responses_response(response: ResponseTemplate) -> Self {
+        let provider = Self::start().await;
+        Mock::given(method("POST"))
+            .and(path("/v1/responses"))
+            .respond_with(response)
+            .mount(&provider.server)
+            .await;
+        provider
+    }
+}
