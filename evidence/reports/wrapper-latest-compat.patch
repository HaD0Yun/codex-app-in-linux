+  const tempRoot = fs.mkdtempSync(path.join(os.tmpdir(), "codex-owl-feature-binding-"));
+  try {
+    const buildDir = path.join(tempRoot, ".vite", "build");
+    fs.mkdirSync(buildDir, { recursive: true });
+    const bundlePath = path.join(buildDir, "workspace-root-drop-handler-test.js");
+    fs.writeFileSync(
+      bundlePath,
+      "function Qe(){let e=process._linkedBinding;if(typeof e!=`function`)throw Error(`Owl feature binding is unavailable`);return Ge.parse(e.call(process,`electron_common_owl_features`))}",
+      "utf8",
+    );
+
+    assert.deepEqual(linuxOwlFeatureBindingPatch.apply(tempRoot), { matched: 1, changed: 1 });
+    const patched = fs.readFileSync(bundlePath, "utf8");
+    assert.match(patched, /process\.platform===`linux`\)return\{isOwlFeatureEnabled:\(\)=>!1\}/);
+    assert.match(patched, /electron_common_owl_features/);
+    assert.deepEqual(linuxOwlFeatureBindingPatch.apply(tempRoot), { matched: 1, changed: 0 });
+  } finally {
+    fs.rmSync(tempRoot, { recursive: true, force: true });
+  }
+});

